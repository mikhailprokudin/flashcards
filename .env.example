# Copy to `.env` and adjust values. Do not commit `.env`.

# --- MySQL (service `mysql` in docker-compose) ---
MYSQL_DATABASE=flashcards
MYSQL_USER=flashcards
MYSQL_PASSWORD=change-me-mysql-user
MYSQL_ROOT_PASSWORD=change-me-mysql-root
MYSQL_PORT=3306

# Connection URL for the API container (`mysql` is the Compose service name).
# If the password contains special characters, URL-encode them (e.g. @ -> %40).
DATABASE_URL=mysql://flashcards:change-me-mysql-user@mysql:3306/flashcards

# --- API ---
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=7d
# Host port published for the API (`host:3000` → container listens on 3000).
PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Frontend (Vite, copy into project root `.env` if needed) ---
# Dev: leave unset to use `/api` (see vite.config.ts proxy to API on port 3000).
# Production: full origin of the API, e.g. https://api.example.com (no trailing slash).
# VITE_API_BASE_URL=
