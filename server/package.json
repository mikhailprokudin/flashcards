{
  "name": "flashcards-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:dist": "node dist/db/migrate.js",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.40.0",
    "fastify": "^5.2.1",
    "mysql2": "^3.14.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.12.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
